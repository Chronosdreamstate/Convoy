{
  "name": "convoy",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev:api": "pnpm --filter @convoy/api dev",
    "build:api": "pnpm --filter @convoy/api build",
    "test:api": "pnpm --filter @convoy/api test",
    "test:mobile": "pnpm --filter @convoy/mobile test",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "db:migrate": "pnpm --filter @convoy/api db:migrate",
    "db:migrate:dev": "pnpm --filter @convoy/api db:migrate:dev"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "prettier": "^3.2.0",
    "typescript": "^5.4.0"
  }
}
