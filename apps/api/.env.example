# =============================================================================
# CONVOY API — Environment Variables
# Copy to .env and fill in real values before running.
# =============================================================================

NODE_ENV=development
PORT=3000

# PostgreSQL (with PostGIS extension)
# Local dev: use docker-compose.yml (runs on localhost:5432)
# Production: use your cloud DB URL (Supabase, Neon, RDS, etc.)
DATABASE_URL=postgresql://convoy:convoy@localhost:5432/convoy

# Redis 7
# Local dev: use docker-compose.yml (runs on localhost:6379)
# Production: use Upstash, Redis Cloud, etc.
REDIS_URL=redis://localhost:6379

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# MUST be changed before deploying to production (app refuses to start with defaults)
JWT_SECRET=change-me-in-production-minimum-32-chars!!
JWT_REFRESH_SECRET=change-me-refresh-secret-minimum-32-chars
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# CORS — comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:8081

# Mapbox — https://account.mapbox.com/access-tokens/
# Required for route calculation and geocoding
MAPBOX_API_TOKEN=pk.YOUR_MAPBOX_PUBLIC_TOKEN_HERE

# Agora RTC — https://console.agora.io/
# Required for PTT (push-to-talk) audio channels
AGORA_APP_ID=
AGORA_APP_CERTIFICATE=

# AWS S3 / Cloudflare R2 — for avatar uploads and drive summary card images
AWS_BUCKET=convoy-media

# Firebase — https://console.firebase.google.com/
# Required for phone OTP (SMS verification)
FIREBASE_PROJECT_ID=your-firebase-project-id

# Nominatim contact email (required by OpenStreetMap usage policy)
NOMINATIM_CONTACT_EMAIL=your-email@example.com
