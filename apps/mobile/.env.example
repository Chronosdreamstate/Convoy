# =============================================================================
# CONVOY Mobile — Expo Public Environment Variables
# Copy to .env and fill in real values before running.
# All EXPO_PUBLIC_ variables are bundled into the client — do NOT put secrets here.
# =============================================================================

# API base URL
# Local dev (Android emulator): http://10.0.2.2:3000
# Local dev (iOS simulator / physical device on same network): http://<your-machine-ip>:3000
# Production: https://api.yourconvoydomain.com
EXPO_PUBLIC_API_URL=http://10.0.2.2:3000

# Mapbox public token — https://account.mapbox.com/access-tokens/
# Use a token scoped to only the scopes needed by the mobile SDK
EXPO_PUBLIC_MAPBOX_TOKEN=pk.YOUR_MAPBOX_PUBLIC_TOKEN_HERE

# Agora App ID (public — no certificate here) — https://console.agora.io/
EXPO_PUBLIC_AGORA_APP_ID=

# Google Sign-In OAuth client IDs — https://console.cloud.google.com/apis/credentials
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
